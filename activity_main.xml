<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ViciousLayer"
            android:textColor="#E03060"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM OVERLAY UTILITY · v1.0"
            android:textColor="#666680"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#11111A"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERMISSIONS"
                android:textColor="#666680"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_perm_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="#2A2A40"
                android:text="GRANT SYSTEM_ALERT_WINDOW"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_perm_notif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:backgroundTint="#2A2A40"
                android:text="GRANT POST_NOTIFICATIONS"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A2A"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <View
                android:id="@+id/status_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#666680" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/lbl_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OverlayService · STOPPED"
                    android:textColor="#E8E8F0"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lbl_service_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to launch"
                    android:textColor="#666680"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#E03060"
                android:text="▶ Start"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#2A2A40"
                android:text="■ Stop"
                android:textColor="#E8E8F0"
                android:enabled="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#11111A"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURATION OPTIONS"
                android:textColor="#666680"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/overlay_label_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#1A1A2A"
                android:hint="Overlay Label Text"
                android:textColor="#E8E8F0"
                android:textColorHint="#666680"
                android:padding="10dp"
                android:inputType="text"
                android:text="ViciousLayer" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opacity"
                android:textColor="#E8E8F0"
                android:layout_marginTop="14dp" />

            <SeekBar
                android:id="@+id/slider_opacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="85"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hex Accent Color"
                android:textColor="#E8E8F0"
                android:layout_marginTop="14dp" />

            <EditText
                android:id="@+id/overlay_color_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#1A1A2A"
                android:text="#E03060"
                android:textColor="#E8E8F0"
                android:padding="10dp"
                android:inputType="textCaps" />

            <CheckBox
                android:id="@+id/chk_passthrough"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="FLAG_NOT_FOCUSABLE (Touch Passthrough)"
                android:textColor="#E8E8F0"
                android:checked="true"
                android:buttonTint="#E03060" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#11111A"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM HARDWARE LOG"
                android:textColor="#666680"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_system_log"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="10dp"
                android:background="#0A0A0F"
                android:padding="8dp"
                android:text="[INFO] ViciousLayer native subsystem ready.\n[WARN] Pending system overlay authorization access."
                android:textColor="#666680"
                android:textSize="11sp"
                android:scrollbars="vertical" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
